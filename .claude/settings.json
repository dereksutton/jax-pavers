{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(app/**)",
      "Write(public/**)",
      "Write(.claude/**)",
      "Write(CLAUDE.md)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(.env*)",
      "Write(.env*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(credentials*)",
      "Bash(rm -rf *)",
      "Bash(git add *.env*)",
      "Bash(git add -f .env*)",
      "Bash(git add *.pem)",
      "Bash(git add *.key)",
      "Bash(cat .env*)",
      "Bash(cat *.pem)",
      "Bash(*DROP*)"
    ]
  }
}
